forwardagent yes
loglevel quiet
identityfile ~/.ssh/id_rsa
compression yes

host cloudtop
  hostname fsareshwala-cloudtop.c.googlers.com

  # typing latency optimizations
  forwardx11 no

  # preserve sessions
  remotecommand shpool attach -f %k
  requesttty yes

host fsareshwala-cloudtop.c.googlers.com
  controlmaster auto
  controlpath ~/.ssh/ctrl-%C
  controlpersist yes

# proxy only when not on corp networks
# sudo glinux-config set manually_enabled_puppet_experiments mnp_proxycommand
match host *.corp.google.com !exec "grep -sqF GOOGLE_ROLE=desktop /etc/lsb-release || /usr/local/bin/corp-ssh-helper -check"
  proxycommand none
