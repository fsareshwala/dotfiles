#!/usr/bin/env fish

source ~/prefix/lib/utilities.fish
ensure_exists gs

# default compression if user doesn't provide one
if test (count $argv) -eq 1
    set compression_type ebook
    set filename $argv[1]
else
    set compression_type $argv[1]
    switch $compression_type
        case screen ebook printer prepress default
            # do nothing
        case '*'
            echo "error: unsupported compression type ($compression_type)"
    end
    set filename $argv[2]
end

set output (remove_extension "$filename")"-compressed.pdf"
gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.6 -dPDFSETTINGS="/$compression_type" -dNOPAUSE -dQUIET \
    -dBATCH -sOutputFile="$output" "$filename"
