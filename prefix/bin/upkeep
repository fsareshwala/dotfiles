#!/usr/bin/env fish

source ~/prefix/lib/utilities.fish

function git_update
    set -l directory $argv[1]
    if not test -d "$directory"
        log_warn "$directory doesn't exist, not updating git"
        return
    end

    cd "$directory"
    set -l git_status (git status --porcelain)
    if test -z "$git_status"
        # no changes in repository, nothing to do
        return
    end

    git add .
    set -l dir_basename (path basename "$directory")
    git commit -m "$dir_basename: automatic update"
    git pull --rebase
    git push
end

git_update ~/personal
