#!/usr/bin/env fish

if test (count $argv) -lt 2
    echo "usage (status current-filename) file file [file...]"
end

set tmplist (mktemp)
set tmpvid (mktemp /tmp/vid-join.XXXXXX)
mv "$tmpvid" "$tmpvid.mp4"
set tmpvid "$tmpvid.mp4"
trap 'rm -f "$tmplist" "$tmpvid"' EXIT

for file in $argv
    echo "file '"(realpath "$file")"'" >>"$tmplist"
end
/opt/homebrew/bin/ffmpeg -y -f concat -safe 0 -i "$tmplist" -c copy "$tmpvid"

set first $argv[1]
touch -r "$first" "$tmpvid"

rm $argv
mv "$tmpvid" "$first"
